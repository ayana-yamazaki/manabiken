			}

			.closing__qr-box {
				width: 140px;
				height: 140px;
				border: 2px solid rgba(0, 0, 0, 0.15);
				border-radius: 8px;
				background: #fff;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.closing__qr-label {
				font-family: "Noto Sans JP", sans-serif;
				font-size: 0.75rem;
				font-weight: 400;
				letter-spacing: 0.1em;
				opacity: 0.45;
			}

			@media (max-width: 768px) {
				.slide__inner--closing {
					gap: 2rem;
				}

				.closing__qr-box {
					width: 120px;
					height: 120px;
				}
			}

			.slide--closing .slide__label {
				color: #1a1a2e;
			}

			/* ========== Responsive: SP ========== */
			@media (max-width: 768px) {
				.slide__inner {
					justify-content: center;
					align-items: flex-end;
					min-height: 100vh;
					padding: 2rem 1.25rem 3rem;
				}

				.slide__text {
					max-width: 100%;
					padding: 2rem 1.5rem;
				}

				.slide__heading {
					font-size: clamp(1.2rem, 4.8vw, 1.76rem);
				}

				.slide__heading--hero {
					font-size: clamp(1.44rem, 6.4vw, 2.4rem);
				}

				.slide__body {
					font-size: 0.85rem;
					line-height: 1.9;
				}

				.slide--title .slide__inner,
				.slide--closing .slide__inner {
					align-items: center;
				}

				.slide--has-image::after {
					background: linear-gradient(
						to bottom,
						rgba(0, 0, 0, 0.1) 0%,
						rgba(0, 0, 0, 0.6) 60%,
						rgba(0, 0, 0, 0.8) 100%
					);
				}
			}

			/* ========== Luminous theme (s21–s29) ========== */
		.slide--luminous {
			color: #1a1a2e;
		}

		.slide--luminous::before {
			background: radial-gradient(
				ellipse at 45% 35%,
				rgba(255, 225, 180, 0.18) 0%,
				rgba(255, 240, 220, 0.08) 40%,
				transparent 70%
			);
			opacity: 1;
		}

		.slide--luminous::after {
			content: "";
			position: absolute;
			inset: 0;
			z-index: 0;
			background: radial-gradient(
				ellipse at 65% 60%,
				rgba(255, 210, 160, 0.1) 0%,
				transparent 50%
			);
			pointer-events: none;
		}

		.slide--luminous .slide__text {
			background: rgba(255, 255, 255, 0.35);
			backdrop-filter: blur(10px);
			-webkit-backdrop-filter: blur(10px);
			border: 1px solid rgba(0, 0, 0, 0.04);
			box-shadow: 0 8px 40px rgba(0, 0, 0, 0.03);
		}

		.slide--luminous .slide__label {
			color: #9a8a78;
		}

		.slide--luminous .slide__body {
			opacity: 0.65;
		}

		.slide--luminous .slide__heading--warm {
			color: #c27830;
		}

		.slide--luminous .scroll-hint {
			color: #1a1a2e;
		}

		/* ========== Water surface animation ========== */
		.river-shimmer__bar {
			transform-origin: center;
		}
		.river-shimmer__bar--1 {
			animation: river-drift-1 11s ease-in-out infinite;
		}
		.river-shimmer__bar--2 {
			animation: river-drift-2 8s ease-in-out infinite;
		}
		.river-shimmer__bar--3 {
			animation: river-drift-3 13s ease-in-out infinite;
		}

		@keyframes river-drift-1 {
			0%, 100% { transform: rotate(-1.5deg) translateX(0); opacity: 1; }
			50% { transform: rotate(-0.5deg) translateX(60px); opacity: 0.4; }
		}
		@keyframes river-drift-2 {
			0%, 100% { transform: rotate(1deg) translateX(0); opacity: 1; }
			50% { transform: rotate(2deg) translateX(-50px); opacity: 0.3; }
		}
		@keyframes river-drift-3 {
			0%, 100% { transform: rotate(-0.8deg) translateX(0); opacity: 1; }
			50% { transform: rotate(0.5deg) translateX(40px); opacity: 0.5; }
		}

		.water-surface {
			position: absolute;
			inset: 0;
			z-index: 2;
			overflow: hidden;
			pointer-events: none;
		}

		.water-surface__orbit {
			position: absolute;
			inset: 0;
		}

		.water-surface__layer {
			position: absolute;
			inset: -40%;
			background-image: url('/images/caustics-texture.png');
			background-repeat: repeat;
		}

		/* --- Light caustics layer (top) --- */
		.water-surface__layer--1 {
			background-size: 900px 900px;
			opacity: 0.35;
			animation: caustic-sway-1 100s linear infinite;
		}

		/* --- Shadow layer (bottom, darker than water) --- */
		.water-surface__layer--2 {
			background-size: 1200px 1200px;
			opacity: 0.3;
			filter: invert(1);
			mix-blend-mode: multiply;
			animation: caustic-sway-2 80s linear infinite reverse;
		}

		/* X/Y orbit wrappers */
		.water-surface__orbit-x--1 {
			animation: orbit-x1 67s ease-in-out infinite alternate;
		}
		.water-surface__orbit-y--1 {
			animation: orbit-y1 53s ease-in-out infinite alternate;
		}
		.water-surface__orbit-x--2 {
			animation: orbit-x2 61s ease-in-out infinite alternate;
		}
		.water-surface__orbit-y--2 {
			animation: orbit-y2 47s ease-in-out infinite alternate;
		}

		@keyframes orbit-x1 {
			0%   { transform: translateX(0); }
			33%  { transform: translateX(-40px); }
			66%  { transform: translateX(25px); }
			100% { transform: translateX(-15px); }
		}
		@keyframes orbit-y1 {
			0%   { transform: translateY(0); }
			25%  { transform: translateY(-30px); }
			50%  { transform: translateY(18px); }
			75%  { transform: translateY(-40px); }
			100% { transform: translateY(10px); }
		}
		@keyframes orbit-x2 {
			0%   { transform: translateX(0); }
			40%  { transform: translateX(35px); }
			70%  { transform: translateX(-22px); }
			100% { transform: translateX(18px); }
		}
		@keyframes orbit-y2 {
			0%   { transform: translateY(0); }
			30%  { transform: translateY(28px); }
			60%  { transform: translateY(-35px); }
			100% { transform: translateY(14px); }
		}

		@keyframes caustic-sway-1 {
			0%   { transform: translateX(0); }
			25%  { transform: translateX(-60px); }
			50%  { transform: translateX(40px); }
			75%  { transform: translateX(-20px); }
			100% { transform: translateX(0); }
		}
		@keyframes caustic-sway-2 {
			0%   { transform: translateX(0) scale(1.05); }
			30%  { transform: translateX(50px) scale(1.05); }
			60%  { transform: translateX(-35px) scale(1.05); }
			100% { transform: translateX(0) scale(1.05); }
		}

		.slide--drift .slide__inner {
			z-index: 3;
		}

		/* ========== Split layout (s17) ========== */
		.slide__inner--split {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0;
			max-width: 100%;
			padding: 4rem 2rem;
		}

		.split__left,
		.split__right {
			width: calc(50% - 4.17%);
			opacity: 0;
			transform: translateY(40px);
			transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
						transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
		}

		.slide--river-source.is-active .split__left,
		.slide--river-source.is-active .split__right {
			opacity: 1;
			transform: translateY(0);
		}

		.slide--river-source.is-active .split__right {
			transition-delay: 0.15s;
		}

		.split__left {
			text-align: left;
			padding-right: clamp(2rem, 4vw, 4rem);
		}

		.split__right {
			text-align: left;
			padding-left: clamp(2rem, 4vw, 4rem);
		}

		.split__left .slide__heading {
			margin-bottom: 0;
		}

		@media (max-width: 768px) {
			.slide__inner--split {
				flex-direction: column;
				gap: 2rem;
				padding: 3rem 1.5rem;
				align-items: stretch;
			}

			.split__left,
			.split__right {
				width: 100%;
				padding: 0 1rem;
			}

			.split__left {
				text-align: left;
				padding-right: 1rem;
			}

			.split__right {
				padding-left: 1rem;
			}
		}

		/* ========== River origin (s17 grey walls + center line) ========== */
		.river-origin {
			position: absolute;
			inset: 0;
			z-index: 0;
			background: linear-gradient(
				to right,
				#48454a 0%, #48454a 45.83%,
				#65636a 45.83%, #65636a 54.17%,
				#48454a 54.17%, #48454a 100%
			);
		}

		/* ========== Float text (outside container) ========== */
		.slide__text--float {
			position: absolute;
			z-index: 10;
			bottom: 8%;
			right: 6%;
			max-width: 50%;
			text-align: right;
			background: transparent;
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			border: none;
			border-radius: 0;
			box-shadow: none;
		}

		@media (max-width: 768px) {
			.slide__text--float {
				bottom: 6%;
				right: 5%;
				left: 5%;
				max-width: none;
				text-align: left;
			}
		}

		/* ========== River → Ocean transition (s18 → s19) ========== */
		.slide__river-start {
			position: absolute;
			bottom: 0;
			left: 0;
			width: 100%;
			height: 36%;
			z-index: 3;
			pointer-events: none;
		}

		.slide__river-start svg {
			width: 100%;
			height: 100%;
			display: block;
		}

		.slide--river-source .slide__inner {
			z-index: 4;
		}

		.slide--drift::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: auto;
			width: 100%;
			height: 70%;
			z-index: 4;
			opacity: 1;
			pointer-events: none;
			background: linear-gradient(
				to bottom,
				#1e8a9a 0%,
				rgba(30, 138, 154, 0.9) 15%,
				rgba(30, 138, 154, 0.7) 30%,
				rgba(30, 138, 154, 0.45) 50%,
				rgba(30, 138, 154, 0.2) 70%,
				rgba(30, 138, 154, 0.08) 85%,
				rgba(30, 138, 154, 0) 100%
			);
		}

		.slide--drift.slide--has-image::after {
			background:
				radial-gradient(ellipse 130% 45% at 25% 98%, rgba(4, 50, 62, 0.35) 0%, transparent 65%),
				radial-gradient(ellipse 90% 38% at 75% 100%, rgba(6, 42, 55, 0.3) 0%, transparent 55%),
				radial-gradient(ellipse 60% 30% at 50% 92%, rgba(3, 55, 65, 0.25) 0%, transparent 50%),
				radial-gradient(ellipse 200% 25% at 60% 105%, rgba(5, 35, 48, 0.2) 0%, transparent 60%),
				linear-gradient(to bottom, transparent 60%, rgba(4, 45, 58, 0.15) 100%);
		}

		/* ========== Slide ID badge (temp) ========== */
		.slide-id {
			position: absolute;
			top: 0.75rem;
			left: 0.75rem;
			z-index: 50;
			font-family: "Noto Sans JP", monospace;
			font-size: 0.7rem;
			font-weight: 700;
			letter-spacing: 0.05em;
			color: #fff;
			background: rgba(0, 0, 0, 0.55);
			padding: 0.2rem 0.5rem;
			border-radius: 4px;
			pointer-events: none;
			user-select: all;
		}

		.slide--light .slide-id {
			color: #1a1a2e;
			background: rgba(0, 0, 0, 0.1);
		}

		/* ========== Mountain Viz (Slide 23) ========== */
		.slide--mountain-viz {
			overflow: hidden;
		}

		.mountain-viz {
			position: absolute;
			inset: 0;
			z-index: 0;
		}

		.mountain-viz__svg {
			width: 100%;
			height: 100%;
			display: block;
		}

		.mtn-fill,
		.mtn-line {
			opacity: 0;
			transition: opacity 1.2s ease-out;
		}

		.slide--mountain-viz.is-active .mtn-fill,
		.slide--mountain-viz.is-active .mtn-line {
			opacity: 1;
		}

		/* water clip + wave: handled entirely in JS via getElementById */

		.slide--mountain-viz::before,
		.slide--mountain-viz::after {
			background: none !important;
			opacity: 0 !important;
		}

		/* ========== Progress bar ========== */
			.progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				background: linear-gradient(90deg, #c4956a, #1a1a2e);
				z-index: 100;
				width: 0%;
				transition: width 0.1s linear;
			}
		</style>

		<div class="progress-bar" id="progressBar"></div>

		<script>
			document.addEventListener("DOMContentLoaded", () => {
				// --- Slide ID badges (temp) ---
				document.querySelectorAll(".slide").forEach((s, i) => {
					const id = `s${String(i + 1).padStart(2, "0")}`;
					s.id = id;
					const b = document.createElement("div");
					b.className = "slide-id";
					b.textContent = id;
					s.appendChild(b);
				});
				const slides = document.querySelectorAll(".slide");
				const progressBar = document.getElementById("progressBar");

				const textObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							const textEl = entry.target.querySelector(".slide__text");
							if (!textEl) return;
							if (entry.isIntersecting) {
								textEl.classList.add("is-visible");
							}
						});
					},
					{ threshold: 0.3 }
				);

				const imageObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-active");
							}
						});
					},
					{ threshold: 0.15 }
				);

				slides.forEach((slide) => {
					textObserver.observe(slide);
					if (slide.classList.contains("slide--has-image") || slide.classList.contains("slide--intro") || slide.classList.contains("slide--mountain-viz") || slide.classList.contains("slide--message") || slide.classList.contains("slide--river-source")) {
						imageObserver.observe(slide);
					}
				});

				function lerp(a, b, t) {
					return a + (b - a) * t;
				}

				function hexToRgb(hex) {
					const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
					return result
						? [parseInt(result[1], 16), parseInt(result[2], 16), parseInt(result[3], 16)]
						: [0, 0, 0];
				}

				function interpolateColor(color1, color2, t) {
					const rgb1 = hexToRgb(color1);
					const rgb2 = hexToRgb(color2);
					const r = Math.round(lerp(rgb1[0], rgb2[0], t));
					const g = Math.round(lerp(rgb1[1], rgb2[1], t));
					const b = Math.round(lerp(rgb1[2], rgb2[2], t));
					return `rgb(${r}, ${g}, ${b})`;
				}

				function onScroll() {
					const scrollTop = window.scrollY;
					const docHeight = document.documentElement.scrollHeight - window.innerHeight;
					const progress = docHeight > 0 ? scrollTop / docHeight : 0;

					if (progressBar) {
						progressBar.style.width = `${progress * 100}%`;
					}

					slides.forEach((slide) => {
						const rect = slide.getBoundingClientRect();
						const slideTop = rect.top;
						const slideHeight = rect.height;
						const viewportHeight = window.innerHeight;

						if (slideTop < viewportHeight && slideTop + slideHeight > 0) {
							const t = Math.max(0, Math.min(1, -slideTop / slideHeight));
							const bgStart = slide.dataset.bgStart || "#1a1a2e";
							const bgEnd = slide.dataset.bgEnd || "#1a1a2e";
							slide.style.backgroundColor = interpolateColor(bgStart, bgEnd, t);
						}
					});

					slides.forEach((slide) => {
						const rect = slide.getBoundingClientRect();
						const textEl = slide.querySelector(".slide__text");
						if (!textEl || !textEl.classList.contains("is-visible")) return;

						const centerOffset = rect.top + rect.height / 2 - window.innerHeight / 2;
						const parallaxY = centerOffset * 0.08;
						textEl.style.transform = `translateY(${parallaxY}px)`;
					});
				}

				window.addEventListener("scroll", onScroll, { passive: true });
				onScroll();

				// Water animation is in a separate <script is:inline> below
			});
		</script>

	<script is:inline>
	(function(){
		var el = document.getElementById("waterLevel");
		var fr = document.getElementById("waveFront");
		var bk = document.getElementById("waveBack");
		var sh = document.getElementById("waveShimmer");
		var sl = document.querySelector(".slide--mountain-viz");
		if(!el || !sl) return;

		var yStart = 600, yEnd = 270, dur = 2, t0 = 0, on = false;

		setInterval(function(){
			var now = Date.now() / 1000;
			var fx = -100 + 100 * Math.cos(2 * Math.PI * now / 14);
			var bx = -100 + 100 * Math.cos(2 * Math.PI * now / 18);
			if(fr) fr.setAttribute("transform","translate("+fx+",0)");
			if(bk) bk.setAttribute("transform","translate("+bx+",0)");
			if(sh) sh.setAttribute("transform","translate("+fx+",0)");

			if(sl.classList.contains("is-active")){
				if(!on){ on = true; t0 = now; }
				var e = now - t0;
				var t = Math.min(e / dur, 1);
				var p = 1 - Math.pow(1 - t, 3);
				el.setAttribute("y", String(yStart - (yStart - yEnd) * p));
				if(sh && e > 3.5){
					var sp = Math.min((e - 3.5) / 0.8, 1);
					sh.setAttribute("opacity", String(sp));
				}
			}
		}, 50);
	})();
	</script>
	</body>
</html>
